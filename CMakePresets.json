{
  "version": 6,
  "configurePresets": [
    {
      "name": "linux-non-rt",
      "displayName": "Linux non-RT",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-cmake-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "HAVE_RT": "OFF",
        "ZDOOM_EXE_NAME": "gzdoom",
        "PK3_QUIET_ZIPDIR": "ON"
      }
    },
    {
      "name": "rtgl-linux",
      "displayName": "RTGL Linux",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-rtgl-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "RG_WITH_SURFACE_XLIB": "ON",
        "RG_WITH_SURFACE_WAYLAND": "OFF",
        "RG_WITH_DX12": "OFF",
        "RG_WITH_NATIVE_DLSS": "OFF",
        "RG_WITH_IMGUI": "OFF",
        "RG_WITH_EXAMPLES": "OFF"
      }
    },
    {
      "name": "linux-rt-probe",
      "displayName": "Linux RT probe",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-cmake-linux-rt",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "HAVE_RT": "ON",
        "ZDOOM_EXE_NAME": "gzdoom",
        "PK3_QUIET_ZIPDIR": "ON"
      },
      "environment": {
        "RTGL1_SDK_PATH": "${sourceDir}/libraries/RTGL",
        "RTGL1_LIBRARY_PATH": "${sourceDir}/build-rtgl-linux/libRTGL1.so"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-non-rt",
      "displayName": "Build Linux non-RT",
      "configurePreset": "linux-non-rt"
    },
    {
      "name": "rtgl-linux",
      "displayName": "Build RTGL Linux",
      "configurePreset": "rtgl-linux"
    },
    {
      "name": "linux-rt-probe",
      "displayName": "Build Linux RT probe",
      "configurePreset": "linux-rt-probe"
    }
  ]
}
