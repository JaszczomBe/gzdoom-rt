{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run non-RT build",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-vscode-linux/gzdoom",
      "args": [
        "-config",
        "${workspaceFolder}/gzdoom-linux.ini",
        "-iwad",
        "/home/rgrabowski/Games/gzdoom-rt/DOOM2.WAD"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "${workspaceFolder}/build-zmusic-linux/source"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "build linux non-rt"
    },
    {
      "name": "Run RT probe build",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build-vscode-linux-rt/gzdoom",
      "args": [
        "-config",
        "${workspaceFolder}/gzdoom-rt-linux.ini",
        "-iwad",
        "/home/rgrabowski/Games/gzdoom-rt/DOOM2.WAD"
      ],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "LD_LIBRARY_PATH",
          "value": "${workspaceFolder}/build-zmusic-linux/source:${workspaceFolder}/build-rtgl-linux"
        },
        {
          "name": "RTGL1_SDK_PATH",
          "value": "${workspaceFolder}/libraries/RTGL"
        },
        {
          "name": "RTGL1_LIBRARY_PATH",
          "value": "${workspaceFolder}/build-rtgl-linux/libRTGL1.so"
        }
      ],
      "externalConsole": false,
      "MIMode": "gdb",
      "preLaunchTask": "build linux rt probe"
    }
  ]
}
