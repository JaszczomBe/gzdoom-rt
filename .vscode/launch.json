{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "GZDoom",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/non-rt/gzdoom",
            "args": [
                "-config",
                "${workspaceFolder}/gzdoom-linux.ini",
                "-iwad",
                "${input:gzdoomIwad}",
                "-file",
                "${workspaceFolder}/../gzdoom-rt-1.0.2/game_support.pk3",
                "${workspaceFolder}/../gzdoom-rt-1.0.2/game_widescreen_gfx.pk3",
                "${workspaceFolder}/../gzdoom-rt-1.0.2/brightmaps.pk3",
                "${workspaceFolder}/../gzdoom-rt-1.0.2/lights.pk3",
                "+r_drawvoxels",
                "1"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${command:cmake.buildDirectory}/zmusic/source"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "build linux non-rt",
            "osx": {
                "program": "${command:cmake.buildDirectory}/non-rt/gzdoom.app/Contents/MacOS/gzdoom",
                "environment": [
                    {
                        "name": "DYLD_LIBRARY_PATH",
                        "value": "${command:cmake.buildDirectory}/zmusic/source"
                    }
                ],
                "MIMode": "lldb",
                "preLaunchTask": "build macos non-rt"
            }
        },
        {
            "name": "GZDoom Ray Tracing",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/rt/gzdoom",
            "args": [
                "-config",
                "${workspaceFolder}/gzdoom-rt-linux.ini",
                "-iwad",
                "${input:gzdoomIwad}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "LD_LIBRARY_PATH",
                    "value": "${command:cmake.buildDirectory}/zmusic/source:${command:cmake.buildDirectory}/rtgl"
                },
                {
                    "name": "RTGL1_SDK_PATH",
                    "value": "${workspaceFolder}/libraries/RTGL"
                },
                {
                    "name": "RTGL1_LIBRARY_PATH",
                    "value": "${command:cmake.buildDirectory}/rtgl/libRTGL1.so"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "build linux rt probe"
        }
    ],
    "inputs": [
        {
            "id": "gzdoomIwad",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "key": "gzdoomIwad",
                "description": "GZDoom IWAD",
                "options": [
                    {
                        "label": "DOOM II: Hell on Earth",
                        "value": "${workspaceFolder}/../wad/DOOM2.WAD"
                    },
                    {
                        "label": "Ultimate Doom",
                        "value": "${workspaceFolder}/../wad/DOOM.WAD"
                    },
                    {
                        "label": "Final Doom: Plutonia",
                        "value": "${workspaceFolder}/../wad/PLUTONIA.WAD"
                    },
                    {
                        "label": "Final Doom: TNT Evilution",
                        "value": "${workspaceFolder}/../wad/TNT.WAD"
                    },
                    {
                        "label": "Heretic",
                        "value": "${workspaceFolder}/../wad/HERETIC.WAD"
                    },
                    {
                        "label": "Hexen",
                        "value": "${workspaceFolder}/../wad/HEXEN.WAD"
                    }
                ]
            }
        }
    ]
}
